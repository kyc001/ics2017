#!/bin/bash

set -e

# In container/devbox setups DISPLAY is often set but unusable. Default to the
# dummy backend unless the user explicitly asks for a real host display.
if [ -z "${SDL_VIDEODRIVER:-}" ] && [ "${NEMU_USE_HOST_DISPLAY:-0}" != "1" ]; then
  export SDL_VIDEODRIVER=dummy
fi

make -C "$NEMU_HOME" run ARGS="-b -l `dirname $1`/nemu-log.txt $1.bin"
