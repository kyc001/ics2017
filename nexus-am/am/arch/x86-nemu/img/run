#!/bin/bash

if [ "${NEMU_USE_HOST_DISPLAY:-0}" = "1" ] && \
   [ -n "${DISPLAY:-}" ] && \
   [ -z "${XAUTHORITY:-}" ] && \
   [ -z "${XDG_RUNTIME_DIR:-}" ]; then
  echo "warning: host display requested, but neither XAUTHORITY nor XDG_RUNTIME_DIR is set." >&2
  echo "warning: if SDL init stalls before 'Welcome to NEMU!', try a real desktop session." >&2
fi

make -C "$NEMU_HOME" run ARGS="-b -l `dirname $1`/nemu-log.txt $1.bin"
