#!/bin/bash

set -e

# In headless environments, SDL init will block or fail unless we provide a
# dummy video backend. Keep real windows on normal desktops by only falling
# back when no display backend is configured.
if [ -z "${SDL_VIDEODRIVER:-}" ] && [ -z "${DISPLAY:-}" ] && [ -z "${WAYLAND_DISPLAY:-}" ]; then
  export SDL_VIDEODRIVER=dummy
fi

make -C "$NEMU_HOME" run ARGS="-b -l `dirname $1`/nemu-log.txt $1.bin"
